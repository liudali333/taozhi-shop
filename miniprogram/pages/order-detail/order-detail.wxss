/* ==================== 页面基础 ==================== */
.detail-page { background: #f5f5f5; min-height: 100vh; padding-bottom: 160rpx; }
.loading-state { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.empty-state { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }

/* ==================== 顶部状态条 ==================== */
.status-bar {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 40rpx; color: #fff;
}
.status-icon { font-size: 48rpx; line-height: 1; }
.status-info { flex: 1; }
.status-name { font-size: 36rpx; font-weight: 700; display: block; }
.status-hint { font-size: 24rpx; opacity: 0.85; display: block; margin-top: 4rpx; }

/* 状态颜色 */
.status-bar.status-pending      { background: linear-gradient(135deg, #ff9500, #ff6b00); }
.status-bar.status-paid        { background: linear-gradient(135deg, #007aff, #0051d4); }
.status-bar.status-delivering  { background: linear-gradient(135deg, #ff3b30, #d63029); }
.status-bar.status-completed   { background: linear-gradient(135deg, #34c759, #248a3d); }
.status-bar.status-cancelled   { background: linear-gradient(135deg, #999, #666); }
/* 配送5步状态 */
.status-bar.status-accepted    { background: linear-gradient(135deg, #007aff, #0051d4); }
.status-bar.status-dispatched  { background: linear-gradient(135deg, #ff9500, #ff6b00); }
.status-bar.status-picked_up   { background: linear-gradient(135deg, #5856d6, #af52de); }
.status-bar.status-delivered   { background: linear-gradient(135deg, #ff3b30, #d63029); }

/* ==================== 卡片通用 ==================== */
.timeline-card, .info-card, .map-card {
  background: #fff; border-radius: 16rpx;
  margin: 24rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #222; }

/* ==================== 时间轴 ==================== */
.timeline-title { font-size: 30rpx; font-weight: 700; color: #222; margin-bottom: 24rpx; }
.timeline { padding-left: 8rpx; }
.tl-item {
  display: flex; align-items: flex-start; position: relative;
  padding-bottom: 36rpx;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-dot {
  width: 22rpx; height: 22rpx; border-radius: 50%;
  background: #ddd; flex-shrink: 0; margin-top: 6rpx; margin-right: 20rpx;
  position: relative; z-index: 1;
}
/* 5步颜色 */
.tl-item.tl-green .tl-dot  { background: #34c759; }
.tl-item.tl-orange .tl-dot { background: #ff9500; }
.tl-item.tl-gray .tl-dot    { background: #ddd; }
.tl-item.tl-green.current .tl-dot  { box-shadow: 0 0 0 6rpx rgba(52,199,89,0.25); }
.tl-item.tl-orange.current .tl-dot { box-shadow: 0 0 0 6rpx rgba(255,149,0,0.25); }
.tl-line {
  position: absolute; left: 10rpx; top: 28rpx;
  bottom: 0; width: 2rpx; background: #eee;
}
.tl-item.tl-green .tl-line  { background: #34c759; }
.tl-item.tl-orange .tl-line { background: #ff9500; }
.tl-item.tl-gray .tl-line  { background: #ddd; }
.tl-content { flex: 1; }
.tl-label {
  font-size: 28rpx; color: #bbb;
}
.tl-item.tl-green .tl-label,
.tl-item.tl-orange .tl-label { color: #333; font-weight: 600; }
.tl-item.tl-orange.current .tl-label { color: #e65100; }
.tl-time { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }

/* ==================== 骑手信息 ==================== */
.rider-card { background: linear-gradient(135deg, #e3f2fd, #f3e5f5); border: 2rpx solid #bbdefb; }
.rider-status-tag {
  font-size: 22rpx; padding: 4rpx 16rpx;
  background: #9c27b0; color: #fff; border-radius: 20rpx;
}
.rider-body { display: flex; align-items: center; gap: 20rpx; }
.rider-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: #e3f2fd; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.rider-info { flex: 1; }
.rider-name { font-size: 32rpx; font-weight: 700; color: #222; display: block; }
.rider-phone { font-size: 26rpx; color: #666; display: block; margin-top: 4rpx; }
.icon-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #e3f2fd; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #007aff; border: none;
}

/* ==================== 地图 ==================== */
.order-map { width: 100%; height: 420rpx; border-radius: 12rpx; }
.map-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.map-title { font-size: 30rpx; font-weight: 700; color: #222; }
.map-tip { font-size: 24rpx; color: #e64340; font-weight: 600; }
.map-legend { display: flex; gap: 24rpx; padding-top: 12rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #888; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.store-dot { background: #e64340; }
.rider-dot { background: #ff9800; }
.user-dot { background: #4caf50; }

/* ==================== 信息行 ==================== */
.info-row { display: flex; gap: 16rpx; align-items: flex-start; margin-bottom: 18rpx; }
.info-row:last-child { margin-bottom: 0; }
.info-label { font-size: 26rpx; color: #999; min-width: 80rpx; padding-top: 4rpx; flex-shrink: 0; }
.info-value { font-size: 28rpx; color: #333; flex: 1; }
.info-value-row { flex: 1; display: flex; align-items: center; gap: 16rpx; }
.address-value { color: #666; line-height: 1.6; }
.remark-value { color: #888; font-style: italic; line-height: 1.5; }
.order-no { font-family: monospace; font-size: 24rpx; color: #666; }

/* 取货码 */
.pickup-code {
  display: flex; align-items: center; gap: 20rpx;
  background: #fff3e0; border-radius: 12rpx;
  padding: 20rpx 24rpx; margin-top: 16rpx;
}
.pickup-label { font-size: 26rpx; color: #888; }
.pickup-value { font-size: 52rpx; font-weight: 900; color: #e65100; font-family: monospace; letter-spacing: 4rpx; }

/* ==================== 商品列表 ==================== */
.product-list { margin: 16rpx 0; }
.product-item { display: flex; align-items: center; gap: 16rpx; padding: 14rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.product-item:last-child { border-bottom: none; }
.p-img { width: 96rpx; height: 96rpx; border-radius: 8rpx; flex-shrink: 0; background: #f5f5f5; }
.p-detail { flex: 1; min-width: 0; }
.p-name { font-size: 28rpx; color: #333; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.p-spec { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.p-right { text-align: right; flex-shrink: 0; }
.p-price { font-size: 28rpx; color: #e64340; font-weight: 700; display: block; }
.p-count { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

/* ==================== 价格汇总 ==================== */
.price-summary { border-top: 1rpx solid #f0f0f0; padding-top: 16rpx; margin-top: 8rpx; }
.price-row { display: flex; justify-content: space-between; padding: 6rpx 0; }
.price-label { font-size: 26rpx; color: #888; }
.price-value { font-size: 26rpx; color: #333; }
.total-row .price-label { font-weight: 700; color: #333; }
.total-row .price-value { font-weight: 700; color: #e64340; font-size: 32rpx; }

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 32rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex; justify-content: flex-end; gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08);
}
.action-btn {
  padding: 20rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 700;
  border: none; line-height: 1;
}
.btn-cancel { background: #f5f5f5; color: #888; }
.btn-pay { background: #e64340; color: #fff; }
.btn-confirm { background: #4caf50; color: #fff; }