.coupon-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #e64340;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #e64340;
  border-radius: 3rpx;
}

.coupon-list {
  padding: 20rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  position: relative;
}

.coupon-item.disabled {
  opacity: 0.5;
}

.coupon-left {
  width: 180rpx;
  padding: 32rpx 20rpx;
  background: linear-gradient(135deg, #e64340 0%, #ff6b6b 100%);
  color: #fff;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-value {
  font-size: 48rpx;
  font-weight: 700;
}

.coupon-condition {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.coupon-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.coupon-time {
  font-size: 24rpx;
  color: #999;
}

.coupon-status {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty image {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.empty text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.bottom-placeholder {
  height: 40rpx;
}
