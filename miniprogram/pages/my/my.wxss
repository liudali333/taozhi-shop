/* pages/my/my.wxss */
.my-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* ========== 用户信息区 ========== */
.user-section {
  background: linear-gradient(135deg, #e64340 0%, #ff6b6b 100%);
  padding: 60rpx 32rpx 48rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 已登录 - 毛玻璃卡片 靠左 */
.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  width: 100%;
  box-sizing: border-box;
}

/* 头像 button - 彻底去除默认样式 */
.avatar-btn {
  display: block;
  padding: 0 !important;
  margin: 0 !important;
  background: none !important;
  border: none !important;
  line-height: 1;
  font-size: 0;
  flex-shrink: 0;
  width: 108rpx;
  height: 108rpx;
  min-width: 108rpx;
  max-width: 108rpx;
  min-height: 108rpx;
  max-height: 108rpx;
  box-sizing: border-box;
  overflow: visible;
  position: relative;
}
.avatar-btn::after {
  border: none !important;
  display: none;
}

/* 头像渐变光环 */
.avatar-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, #e64340, #ff9500);
  box-sizing: border-box;
  margin: 0 auto;
}
.avatar-ring .avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
  background: #f5f5f5;
}
/* 兼容直接引用 .avatar 的地方 */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: block;
}

/* 相机编辑角标 */
.avatar-edit {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 32rpx;
  height: 32rpx;
  background: #e64340;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2);
  border: 2rpx solid #fff;
  z-index: 2;
}
.camera-icon {
  width: 16rpx;
  height: 16rpx;
}

/* 昵称+副标题 */
.user-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 20rpx;
  min-width: 0;
  flex: 1;
}
.user-name-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  line-height: 44rpx;
  height: 44rpx;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}
.user-name-input::placeholder {
  color: rgba(255,255,255,0.75);
}
.user-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 34rpx;
}



/* 未登录 */
.login-tip {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.login-tip .avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.login-text {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}
.login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
.login-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 6rpx;
}
.login-btn {
  background: #fff;
  color: #e64340;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  border: none;
  flex-shrink: 0;
  margin-left: 8rpx;
}
.login-btn::after { border: none; }

/* ========== 订单与资产 ========== */
.order-assets {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.more {
  display: flex;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}
.more image {
  width: 24rpx;
  height: 24rpx;
  margin-left: 6rpx;
}

/* 资产卡片 */
.assets-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 30rpx;
}
.asset-item {
  flex: 1;
  text-align: center;
}
.asset-num {
  display: block;
  font-size: 36rpx;
  color: #e64340;
  font-weight: bold;
}
.asset-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ========== 功能列表 ========== */
.menu-section {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* ========== 昵称弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 500;
}
.nickname-modal {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  z-index: 501;
  box-sizing: border-box;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 36rpx;
}
.modal-avatar-row {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
}
.modal-avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  line-height: normal;
  padding: 0;
}
.modal-avatar-btn::after { border: none; }
.modal-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #e8e8e8;
}
.modal-avatar-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
.modal-name-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 32rpx;
  border: none;
  outline: none;
}
.modal-name-input::placeholder { color: #bbb; }
.modal-btn-row {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.modal-btn.cancel { background: #f0f0f0; color: #666; }
.modal-btn.confirm { background: #e64340; color: #fff; }

/* ========== 底部占位 ========== */
.tab-placeholder { height: 100rpx; }
