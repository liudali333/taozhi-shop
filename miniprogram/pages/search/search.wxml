<view class="search-page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <image src="/images/search.png" mode="aspectFit"></image>
      <input 
        placeholder="搜索商品名称/规格/分类/货号" 
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        focus="true"
      />
    </view>
    <text class="cancel-btn" bindtap="onCancel">取消</text>
  </view>
  
  <!-- 搜索历史 -->
  <view class="history-section" wx:if="{{!keyword && historyList.length > 0}}">
    <view class="section-header">
      <text class="title">搜索历史</text>
      <text class="clear" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-tags">
      <text 
        wx:for="{{historyList}}" 
        wx:key="index"
        class="tag"
        bindtap="tapHistory"
        data-word="{{item}}"
      >{{item}}</text>
    </view>
  </view>
  
  <!-- 热门搜索 -->
  <view class="hot-section" wx:if="{{!keyword}}">
    <view class="section-header">
      <text class="title">🔥 热门搜索</text>
    </view>
    <view class="history-tags">
      <text 
        wx:for="{{hotList}}" 
        wx:key="index"
        class="tag"
        bindtap="tapHistory"
        data-word="{{item}}"
      >{{item}}</text>
    </view>
  </view>
  
  <!-- 搜索结果 -->
  <view class="result-list" wx:if="{{keyword && results.length > 0}}">
    <view 
      class="result-item {{item.stock <= 0 ? 'out' : ''}}"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="goProduct"
      data-id="{{item.id}}"
    >
      <image src="{{item.image}}" mode="aspectFill"></image>
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <view class="result-meta">
          <text class="result-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
          <text class="result-cat" wx:if="{{item.category_l2}}">{{item.category_l1}}/{{item.category_l2}}</text>
          <text class="result-cat" wx:elif="{{item.category_l1}}">{{item.category_l1}}</text>
        </view>
        <view class="result-bottom">
          <view class="result-price-wrap">
            <text class="result-price">¥{{item.sale_price || item.price}}</text>
            <text class="result-orig" wx:if="{{item.sale_price < item.price}}">¥{{item.price}}</text>
          </view>
          <text class="result-stock {{item.stock <= 0 ? 'zero' : ''}}">
            {{item.stock > 0 ? '有货' : '售罄'}}
          </text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 无结果 -->
  <view class="no-result" wx:if="{{keyword && results.length === 0 && !loading}}">
    <image src="/images/empty.png" mode="aspectFit" class="empty-img"></image>
    <text>未找到「{{keyword}}」相关商品</text>
    <text class="hint">换个关键词试试</text>
  </view>
  
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>搜索中...</text>
  </view>
</view>
