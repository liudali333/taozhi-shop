.receive-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.coupon-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 60rpx;
}

.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #e64340 0%, #ff6b6b 100%);
  color: #fff;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.coupon-value {
  font-size: 64rpx;
  font-weight: 700;
}

.coupon-condition {
  font-size: 24rpx;
  margin-top: 12rpx;
  opacity: 0.9;
}

.coupon-right {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.coupon-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
}

.coupon-time {
  font-size: 26rpx;
  color: #999;
}

.loading, .error {
  text-align: center;
  padding: 120rpx 0;
}

.loading text, .error text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  background: #e64340;
  color: #fff;
  border: none;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.receive-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #e64340;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.receive-btn:active {
  background: #d92b28;
}

.received {
  text-align: center;
  padding: 60rpx 0;
}

.received image {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.received text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.received-tip {
  font-size: 26rpx !important;
  color: #999 !important;
  margin-bottom: 30rpx !important;
}

.go-use-btn {
  background: #e64340;
  color: #fff;
  border: none;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* ===== 自动领取中（旋转动画） ===== */
.auto-claiming {
  text-align: center;
  padding: 80rpx 0;
}

.auto-claiming text {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-top: 30rpx;
}

.spin {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f5f5f5;
  border-top-color: #e64340;
  border-radius: 50%;
  margin: 0 auto;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
