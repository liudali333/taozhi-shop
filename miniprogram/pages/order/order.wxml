<view class="order-page">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:elif="{{orders.length > 0}}">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" catchtap="goDetail" data-no="{{item.order_no}}">
      <view class="order-header">
        <text class="order-store">{{item.store_name}}</text>
        <text class="order-status status-{{item.status}}">{{statusText[item.status]}}</text>
      </view>
      <view class="order-products">
        <view class="product-item" wx:for="{{item.products}}" wx:key="id" wx:for-item="p">
          <image src="{{p.image}}" mode="aspectFill"></image>
          <view class="p-info">
            <text class="p-name">{{p.name}}</text>
            <text class="p-count">x{{p.count}}</text>
          </view>
          <text class="p-price">¥{{p.price}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.create_time}}</text>
        <view class="order-total">
          <text>共{{item.total_count}}件</text>
          <text class="total-price">¥{{item.total_price}}</text>
        </view>
      </view>
      <view class="order-actions">
        <view class="action-btn btn-cancel" wx:if="{{item.status === 'pending'}}" catchtap="cancelOrder" data-no="{{item.order_no}}" data-id="{{item.id}}">取消订单</view>
        <view class="action-btn btn-pay" wx:if="{{item.status === 'pending'}}" catchtap="payOrder" data-no="{{item.order_no}}" data-id="{{item.id}}">去支付</view>
        <view class="action-btn btn-confirm" wx:if="{{item.status === 'delivering' || item.status === 'shipped'}}" catchtap="confirmReceive" data-no="{{item.order_no}}" data-id="{{item.id}}">确认收货</view>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image src="/images/order-empty.png" mode="aspectFit"></image>
    <text>暂无订单</text>
  </view>
</view>
