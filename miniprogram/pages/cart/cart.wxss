.cart-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 地址栏 */
.address-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.address-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}
.address-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.address-info {
  flex: 1;
  min-width: 0;
}
.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.address-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

/* 门店小提示 */
.store-tip {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 14rpx 30rpx;
  background: #fafafa;
  font-size: 22rpx;
  color: #888;
  border-bottom: 1rpx solid #f0f0f0;
}
.store-tip-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}
.store-tip-text {
  margin-right: 12rpx;
}
.notice-text {
  color: #b25e00;
  margin-left: 4rpx;
}

/* 配送范围提示 */
.range-tip {
  background: #fff0f0;
  color: #c41e3a;
  font-size: 24rpx;
  padding: 16rpx 30rpx;
  text-align: center;
}

/* 商品列表 */
.cart-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}
.cart-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.cart-item:last-child { border-bottom: none; }

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}
.item-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}
.delete-btn {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 0 4rpx 16rpx;
}
.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}
.item-price {
  font-size: 32rpx;
  color: #e64340;
  font-weight: bold;
}
.count-control {
  display: flex;
  align-items: center;
}
.btn-minus, .btn-plus {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}
.count {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 空购物车 */
.empty-cart {
  padding: 100rpx 0;
  text-align: center;
}
.empty-cart image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.empty-cart text {
  display: block;
  color: #999;
  font-size: 28rpx;
}
.go-shop {
  margin-top: 30rpx;
  display: inline-block;
  padding: 20rpx 60rpx;
  background: #e64340;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 配送/备注区块 */
.delivery-section, .remark-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}
.delivery-options {
  display: flex;
  gap: 20rpx;
}
.option {
  flex: 1;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.2s;
}
.option.active {
  border-color: #e64340;
  background: rgba(230, 67, 64, 0.05);
}
.option.disabled {
  opacity: 0.4;
  pointer-events: none;
}
.option image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}
.option text {
  display: block;
  font-size: 28rpx;
  color: #333;
}
.option .tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.option .tip-warn {
  color: #e64340;
}
.remark-input {
  width: 100%;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 底部结算 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}
.total-info {
  display: flex;
  align-items: baseline;
}
.total-label {
  font-size: 28rpx;
  color: #666;
}
.total-price {
  font-size: 40rpx;
  color: #e64340;
  font-weight: bold;
  margin-left: 12rpx;
}
.checkout-btn {
  background: #e64340;
  color: #fff;
  padding: 24rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.btn-disabled {
  background: #ccc !important;
  pointer-events: none;
}

/* 底部支付栏（下单后） */
.pay-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.pay-info {
  display: flex;
  align-items: baseline;
}
.pay-label {
  font-size: 26rpx;
  color: #666;
}
.pay-amount {
  font-size: 40rpx;
  color: #e64340;
  font-weight: bold;
  margin-left: 12rpx;
}
.pay-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.pay-later {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
}
.pay-btn {
  display: flex;
  align-items: center;
  background: #07c160;
  color: #fff;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.pay-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  background: #fff;
  color: #07c160;
  border-radius: 50%;
  font-weight: bold;
  font-size: 26rpx;
  margin-right: 10rpx;
}
