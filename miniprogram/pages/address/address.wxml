<view class="address-page">
  <!-- 地址列表 -->
  <view class="address-list" wx:if="{{addressList.length > 0}}">
    <view class="address-card" wx:for="{{addressList}}" wx:key="id" catchtap="selectAddress" data-item="{{item}}">
      <view class="card-top">
        <text class="consignee">{{item.name}}</text>
        <text class="phone">{{item.phone}}</text>
        <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
      </view>
      <view class="address-detail">
        <text class="region">{{item.region}}</text>
        <text class="detail-addr">{{item.detail}}</text>
      </view>
      <view class="card-actions">
        <view class="action-item" catchtap="toggleDefault" data-id="{{item.id}}" data-default="{{item.isDefault}}">
          <image src="/images/location.png" mode="aspectFit"></image>
          <text wx:if="{{item.isDefault}}">取消默认</text>
          <text wx:else>设为默认</text>
        </view>
        <view class="action-item" catchtap="editAddress" data-item="{{item}}">
          <image src="/images/menu-about.png" mode="aspectFit"></image>
          <text>编辑</text>
        </view>
        <view class="action-item" catchtap="deleteAddress" data-id="{{item.id}}">
          <image src="/images/menu-service.png" mode="aspectFit"></image>
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 空地址 -->
  <view class="empty-address" wx:else>
    <image src="/images/order-empty.png" mode="aspectFit"></image>
    <text>暂无收货地址</text>
    <text class="sub-tip">点击下方按钮添加</text>
  </view>
  
  <!-- 新增地址按钮 -->
  <view class="add-btn-wrap">
    <view class="add-btn" catchtap="addAddress">
      <image src="/images/add.png" mode="aspectFit"></image>
      <text>新增收货地址</text>
    </view>
  </view>
</view>

<!-- 地址编辑弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" catchtap="closeModal"></view>
<view class="modal-content safe-bottom" wx:if="{{showModal}}">
  <view class="modal-header">
    <text>{{editingIndex === -1 ? '新增地址' : '编辑地址'}}</text>
    <view class="close-btn" catchtap="closeModal">×</view>
  </view>
  
  <scroll-view class="modal-body" scroll-y>
    <view class="form-group">
      <text class="form-label">收货人</text>
      <input class="form-input" placeholder="请输入收货人姓名" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
    </view>
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{form.phone}}" bindinput="onFormInput" data-field="phone" />
    </view>
    <view class="form-group">
      <text class="form-label">所在地区</text>
      <picker mode="region" value="{{form.regionArr}}" bindchange="onRegionChange">
        <view class="picker-value">{{form.region || '请选择省/市/区'}}</view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">详细地址</text>
      <view style="display:flex;align-items:flex-start;gap:8px;">
        <textarea class="form-textarea" placeholder="街道、门牌号等" value="{{form.detail}}" bindinput="onFormInput" data-field="detail" style="flex:1;" />
        <button class="locate-btn" bindtap="onLocateAddress">🗺️ 定位</button>
      </view>
    </view>
    <view class="form-group switch-group">
      <text class="form-label">设为默认地址</text>
      <switch checked="{{form.isDefault}}" color="#e64340" bindchange="onDefaultChange" />
    </view>
  </scroll-view>
  
  <view class="modal-footer">
    <view class="save-btn" catchtap="saveAddress">保存地址</view>
  </view>
</view>
