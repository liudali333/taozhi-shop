.home {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f7;
}

/* 顶部定位栏 */
.location-bar-top {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #fff;
  gap: 12rpx;
}
.location-bar-top .location-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
.location-bar-top .location-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex:1;
}
.open-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.open-status.open {
  background: #e8f5e9;
  color: #2e7d32;
}
.open-status.closed {
  background: #f5f5f5;
  color: #999;
}

/* 公告栏 */
.notice-bar {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3cd 100%);
  color: #b25e00;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  line-height: 1.4;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  height: 64rpx;
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #999;
}

/* 内容区 */
.content-area {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏（树形结构） */
.category-sidebar {
  width: 200rpx;
  background: #f8f8f8;
  height: 100%;
}

/* 一级分类组 */
.category-group {
  border-bottom: 1rpx solid #f0f0f0;
}

/* 一级分类项 */
.category-l1-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 20rpx;
  font-size: 25rpx;
  color: #666;
  background: #f8f8f8;
  transition: all 0.2s;
  border-left: 4rpx solid transparent;
}
.category-l1-item.expanded {
  background: #f0f0f0;
}
.category-l1-item.active {
  background: #fff;
  color: #e64340;
  font-weight: 600;
  font-size: 26rpx;
  border-left-color: #e64340;
}
.l1-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.l1-arrow {
  font-size: 18rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* 二级分类容器 */
.category-l2-wrap {
  background: #fff;
  border-top: 1rpx solid #f5f5f5;
}

/* 二级分类项 */
.category-l2-item {
  padding: 22rpx 20rpx 22rpx 40rpx;
  font-size: 23rpx;
  color: #666;
  border-bottom: 1rpx solid #f8f8f8;
  transition: all 0.2s;
  position: relative;
}
.category-l2-item.active {
  color: #e64340;
  font-weight: 600;
  background: #fff0f0;
}
.category-l2-item.active::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #e64340;
  border-radius: 3rpx;
}
.l2-text {
  padding-left: 12rpx;
}

/* 右侧商品区 */
.product-area {
  flex: 1;
  background: #fff;
  height: 100%;
  padding: 0 20rpx 24rpx;
  overflow-y: auto;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 220rpx;
  margin: 20rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  background: #f5f5f7;
}

/* 分类提示条 */
.category-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 4rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}
.tip-count {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-img {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 商品列表 */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.product-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  position: relative;
}
.product-item.out-of-stock {
  opacity: 0.65;
}

/* 商品图片 */
.product-img-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}
.product-img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f5f5f7;
}
.stock-out-tag {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.discount-tag {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #e64340;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx 8rpx 8rpx 0;
  font-weight: 500;
}

/* 商品信息 */
.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.product-name {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}
.product-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.product-tags {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 6rpx;
  font-size: 22rpx;
}
.tag-l1 {
  color: #e64340;
  background: #fff0f0;
  padding: 1rpx 8rpx;
  border-radius: 4rpx;
}
.tag-sep {
  color: #ddd;
}
.tag-l2 {
  color: #666;
  background: #f5f5f5;
  padding: 1rpx 8rpx;
  border-radius: 4rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}
.price-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.sale-price {
  font-size: 34rpx;
  color: #e64340;
  font-weight: 700;
}
.orig-price {
  font-size: 24rpx;
  color: #bbb;
  text-decoration: line-through;
}
.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  background: #e64340;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.add-cart-btn.disabled {
  background: #ccc;
}
.add-cart-btn image {
  width: 32rpx;
  height: 32rpx;
}
.stock-tip {
  font-size: 22rpx;
  color: #ff9800;
  margin-top: 4rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #999;
}
.load-more.loading {
  color: #e64340;
}
.load-more.done {
  color: #ddd;
}

/* 底部购物篮 */
.cart-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: #2c2c2c;
  color: #fff;
  min-height: 100rpx;
}
.cart-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}
.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #e64340;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.cart-icon {
  width: 44rpx;
  height: 44rpx;
}
.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #fff;
  color: #e64340;
  font-size: 20rpx;
  border-radius: 20rpx;
  padding: 2rpx 10rpx;
  min-width: 32rpx;
  text-align: center;
  font-weight: 600;
  line-height: 1.4;
}
.cart-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.cart-store {
  font-size: 22rpx;
  color: #ccc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-total {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}
.cart-right {
  background: #e64340;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
